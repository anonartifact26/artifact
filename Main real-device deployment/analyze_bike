        excel_path = resolve_excel_path(ROOT, order, profile)
        df = load_profile_excel(excel_path, order, profile)
        all_runs[(order, profile)] = df

        batt = compute_battery_metrics(df, bin_minutes=2)

        if profile == "gps":
            points_for_count = get_gps_ground_truth_points(df)
        else:
            points_for_count = get_released_points(df)

        run_summary_rows.append({
            "order": order,
            "profile": profile,
            "source_file": excel_path.name,
            "selected_sheet": df["selected_sheet"].iloc[0] if "selected_sheet" in df.columns and len(df) else None,
            "n_rows_total": len(df),
            "n_points_used": len(points_for_count),
            "start_battery": batt["start_battery"],
            "end_battery": batt["end_battery"],
