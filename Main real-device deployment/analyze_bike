def haversine_m(lat1, lon1, lat2, lon2):
    R = 6371000.0
    lat1 = np.radians(lat1)
    lon1 = np.radians(lon1)
    lat2 = np.radians(lat2)
    lon2 = np.radians(lon2)

    dlat = lat2 - lat1
    dlon = lon2 - lon1

    a = np.sin(dlat / 2.0) ** 2 + np.cos(lat1) * np.cos(lat2) * np.sin(dlon / 2.0) ** 2
    c = 2 * np.arctan2(np.sqrt(a), np.sqrt(1 - a))
    return R * c


def ensure_numeric(df, cols):
    for c in cols:
        if c in df.columns:
            df[c] = pd.to_numeric(df[c], errors="coerce")
    return df


def parse_bool_like(s):
    if pd.isna(s):
        return False
    if isinstance(s, (bool, np.bool_)):
        return bool(s)
    s = str(s).strip().lower()
    return s in {"1", "true", "t", "yes", "y", "on"}


def parse_battery_pct_value(x):
    if pd.isna(x):
        return np.nan
    if isinstance(x, (int, float, np.integer, np.floating)):
        return float(x)

    s = str(x).strip()
    if not s:
        return np.nan

    s = s.replace("%", "")
    m = re.search(r"-?\d+(\.\d+)?", s)
    if m:
        try:
            return float(m.group())
        except Exception:
            return np.nan
    return np.nan


def find_main_excel(folder: Path):
    files = list(folder.glob("*.xlsx")) + list(folder.glob("*.xls"))
    if not files:
        raise FileNotFoundError(f"No Excel file found in: {folder}")
    files = sorted(files, key=lambda p: p.stat().st_size, reverse=True)
    return files[0]


def resolve_excel_path(root: Path, order: str, profile: str):
    direct_xlsx = root / order / f"{profile}.xlsx"
    direct_xls = root / order / f"{profile}.xls"

    if direct_xlsx.exists():
        return direct_xlsx
    if direct_xls.exists():
        return direct_xls

    folder = root / order / profile
    if folder.is_dir():
        return find_main_excel(folder)

    raise FileNotFoundError(
        f"Excel file not found for order={order}, profile={profile}. "
        f"Tried: {direct_xlsx}, {direct_xls}, and folder {folder}"
    )


def read_excel_all_sheets(excel_path: Path):
    suffix = excel_path.suffix.lower()
    if suffix == ".xlsx":
        engine = "openpyxl"
    elif suffix == ".xls":
        engine = "xlrd"
    else:
        raise ValueError(f"Unsupported file type: {excel_path}")

    xls = pd.ExcelFile(excel_path, engine=engine)
    sheet_dict = {}
    for s in xls.sheet_names:
        sheet_dict[s] = pd.read_excel(excel_path, sheet_name=s, engine=engine)
    return sheet_dict


def choose_best_sheet(sheet_dict, order_name, profile_name, excel_path):
    best_sheet_name = None
    best_df = None
    best_count = -1

    for sheet_name, raw_df in sheet_dict.items():
        tmp = raw_df.copy()
        if "battery_pct" in tmp.columns:
            cnt = tmp["battery_pct"].apply(parse_battery_pct_value).notna().sum()
        else:
            cnt = 0

        if cnt > best_count:
            best_count = cnt
            best_sheet_name = sheet_name
            best_df = raw_df

    if best_df is None:
        first_sheet = next(iter(sheet_dict.keys()))
        best_sheet_name = first_sheet
        best_df = sheet_dict[first_sheet]

    return best_sheet_name, best_df


def load_profile_excel(excel_path: Path, order_name: str, profile_name: str):
    sheet_dict = read_excel_all_sheets(excel_path)
    selected_sheet, df = choose_best_sheet(sheet_dict, order_name, profile_name, excel_path)
    df = df.copy()

    expected_cols = [
        "timestamp", "elapsed_ms", "event", "mode", "intent",
        "raw_provider", "raw_lat", "raw_lon", "raw_accuracy_m",
        "released_lat", "released_lon", "release_offset_m",
        "epsilon_used", "release_triggered", "raw_update_count",
        "release_count", "gps_reference_count", "battery_pct",
        "is_charging", "charge_plug", "device", "android_version", "note"
    ]
    missing = [c for c in expected_cols if c not in df.columns]
    if missing:
        print(f"[Warning] {excel_path} missing columns: {missing}")

    numeric_cols = [
        "elapsed_ms", "raw_lat", "raw_lon", "raw_accuracy_m",
        "released_lat", "released_lon", "release_offset_m",
        "epsilon_used", "raw_update_count", "release_count",
        "gps_reference_count"
    ]
    df = ensure_numeric(df, numeric_cols)

    if "battery_pct" in df.columns:
        df["battery_pct"] = df["battery_pct"].apply(parse_battery_pct_value)
    else:
        df["battery_pct"] = np.nan

    if "timestamp" in df.columns:
        ts_num = pd.to_numeric(df["timestamp"], errors="coerce")
        df["timestamp_parsed"] = pd.to_datetime(ts_num, unit="ms", errors="coerce")
    else:
        df["timestamp_parsed"] = pd.NaT

    if "release_triggered" in df.columns:
        df["release_triggered_bool"] = df["release_triggered"].apply(parse_bool_like)
    else:
        df["release_triggered_bool"] = False

    if "is_charging" in df.columns:
        df["is_charging_bool"] = df["is_charging"].apply(parse_bool_like)
    else:
        df["is_charging_bool"] = False

    df["order"] = order_name
    df["profile"] = profile_name
    df["source_file"] = excel_path.name
    df["selected_sheet"] = selected_sheet
    return df


def sort_by_best_time(df):
    d = df.copy()

    if "timestamp_parsed" in d.columns and d["timestamp_parsed"].notna().sum() >= 2:
        if "elapsed_ms" in d.columns:
            d = d.sort_values(["timestamp_parsed", "elapsed_ms"], na_position="last")
        else:
            d = d.sort_values(["timestamp_parsed"], na_position="last")
        return d.reset_index(drop=True), "timestamp_parsed"

    if "elapsed_ms" in d.columns and pd.to_numeric(d["elapsed_ms"], errors="coerce").notna().sum() >= 2:
        d = d.sort_values(["elapsed_ms"], na_position="last")
        return d.reset_index(drop=True), "elapsed_ms"

    return d.reset_index(drop=True), "row_order"


def get_released_points(df):
    d = df.copy()

    if ONLY_RELEASED_POINTS and "release_triggered_bool" in d.columns:
        d = d[d["release_triggered_bool"] == True].copy()

    d = d.dropna(subset=["released_lat", "released_lon"]).copy()
    d, _ = sort_by_best_time(d)
    return d


def get_gps_ground_truth_points(df):
    d = df.copy()
    d = d.dropna(subset=["raw_lat", "raw_lon"]).copy()
    d, _ = sort_by_best_time(d)
    return d


def infer_duration_hours(df):
    if len(df) < 2:
        return np.nan

    if "timestamp_parsed" in df.columns:
        t = df["timestamp_parsed"].dropna()
        if len(t) >= 2:
            dur_s = (t.iloc[-1] - t.iloc[0]).total_seconds()
            if dur_s > 0:
                return dur_s / 3600.0

    if "elapsed_ms" in df.columns:
        vals = pd.to_numeric(df["elapsed_ms"], errors="coerce").dropna()
        if len(vals) >= 2:
            dur_ms = vals.iloc[-1] - vals.iloc[0]
            if dur_ms > 0:
                return dur_ms / 1000.0 / 3600.0

    return np.nan


def simple_linear_fit(x, y):
    x = np.asarray(x, dtype=float)
    y = np.asarray(y, dtype=float)
    mask = np.isfinite(x) & np.isfinite(y)
    x = x[mask]
    y = y[mask]
    if len(x) < 2:
        return None, None, None
    coef = np.polyfit(x, y, 1)
    slope, intercept = coef[0], coef[1]
    y_pred = slope * x + intercept
    ss_res = np.sum((y - y_pred) ** 2)
    ss_tot = np.sum((y - np.mean(y)) ** 2)
    r2 = np.nan if ss_tot == 0 else 1 - ss_res / ss_tot
    return slope, intercept, r2


def build_battery_fit_dataframe(df):
    d = df.copy()

    raw_batt_rows = int(d["battery_pct"].notna().sum()) if "battery_pct" in d.columns else 0

    if "is_charging_bool" in d.columns:
        d = d[d["is_charging_bool"] == False].copy()

    non_charging_rows = len(d)

    d = d.dropna(subset=["battery_pct"]).copy()
    valid_battery_rows = len(d)

    if len(d) < 2:
        return d, {
            "raw_batt_rows": raw_batt_rows,
            "non_charging_rows": non_charging_rows,
            "valid_battery_rows": valid_battery_rows,
            "sort_basis": "none",
            "time_basis": "none",
            "reason": "fewer_than_2_valid_battery_points"
        }

    d, sort_basis = sort_by_best_time(d)

    if "timestamp_parsed" in d.columns and d["timestamp_parsed"].notna().sum() >= 2:
        t = d["timestamp_parsed"]
        t0 = t.dropna().iloc[0]
        d["time_h_from_start"] = (t - t0).dt.total_seconds() / 3600.0
        time_basis = "timestamp_parsed"
    elif "elapsed_ms" in d.columns and pd.to_numeric(d["elapsed_ms"], errors="coerce").notna().sum() >= 2:
        em = pd.to_numeric(d["elapsed_ms"], errors="coerce")
        t0 = em.dropna().iloc[0]
        d["time_h_from_start"] = (em - t0) / 1000.0 / 3600.0
        time_basis = "elapsed_ms"
    else:
        d["time_h_from_start"] = np.arange(len(d), dtype=float)
        time_basis = "row_index"

    d["time_h_from_start"] = pd.to_numeric(d["time_h_from_start"], errors="coerce")

    return d, {
        "raw_batt_rows": raw_batt_rows,
        "non_charging_rows": non_charging_rows,
        "valid_battery_rows": valid_battery_rows,
        "sort_basis": sort_basis,
        "time_basis": time_basis,
        "reason": "ok"
    }


def compute_battery_metrics(df, bin_minutes=2):
    d, meta = build_battery_fit_dataframe(df)

    if len(d) < 2:
        duration_h = infer_duration_hours(df)
        return {
            "start_battery": np.nan,
            "end_battery": np.nan,
            "battery_drop_pct": np.nan,
            "duration_h": duration_h,
            "drain_pct_per_h": np.nan,
            "drain_method": "linear_fit_insufficient_data",
            "raw_batt_rows": meta["raw_batt_rows"],
            "non_charging_rows": meta["non_charging_rows"],
            "valid_battery_rows": meta["valid_battery_rows"],
            "battery_reason": meta["reason"],
            "battery_sort_basis": meta["sort_basis"],
            "battery_time_basis": meta["time_basis"],
            "battery_slope": np.nan,
            "battery_intercept": np.nan,
            "battery_r2": np.nan,
        }

    x = d["time_h_from_start"].to_numpy(dtype=float)
    y = d["battery_pct"].to_numpy(dtype=float)

    slope, intercept, r2 = simple_linear_fit(x, y)

    if slope is None:
        duration_h = infer_duration_hours(d)
        return {
            "start_battery": float(y[0]) if len(y) else np.nan,
            "end_battery": float(y[-1]) if len(y) else np.nan,
            "battery_drop_pct": (float(y[0]) - float(y[-1])) if len(y) >= 2 else np.nan,
            "duration_h": duration_h,
            "drain_pct_per_h": np.nan,
            "drain_method": "linear_fit_failed",
            "raw_batt_rows": meta["raw_batt_rows"],
            "non_charging_rows": meta["non_charging_rows"],
            "valid_battery_rows": meta["valid_battery_rows"],
            "battery_reason": "linear_fit_failed",
            "battery_sort_basis": meta["sort_basis"],
            "battery_time_basis": meta["time_basis"],
            "battery_slope": np.nan,
            "battery_intercept": np.nan,
            "battery_r2": np.nan,
        }

    duration_h = np.nanmax(x) - np.nanmin(x) if len(x) >= 2 else np.nan
    if not np.isfinite(duration_h) or duration_h <= 0:
        duration_h = infer_duration_hours(d)

    start_b_fit = intercept + slope * np.nanmin(x)
    end_b_fit = intercept + slope * np.nanmax(x)
    drop_fit = start_b_fit - end_b_fit
    drain_rate = -slope

    return {
        "start_battery": float(start_b_fit),
        "end_battery": float(end_b_fit),
        "battery_drop_pct": float(drop_fit),
        "duration_h": float(duration_h) if pd.notna(duration_h) else np.nan,
        "drain_pct_per_h": float(drain_rate),
        "drain_method": "linear_fit",
        "raw_batt_rows": meta["raw_batt_rows"],
        "non_charging_rows": meta["non_charging_rows"],
        "valid_battery_rows": meta["valid_battery_rows"],
        "battery_reason": meta["reason"],
        "battery_sort_basis": meta["sort_basis"],
        "battery_time_basis": meta["time_basis"],
        "battery_slope": float(slope),
        "battery_intercept": float(intercept),
        "battery_r2": float(r2) if pd.notna(r2) else np.nan,
    }


def nearest_path_error_to_reference(query_lat, query_lon, ref_lats, ref_lons):
    dists = haversine_m(query_lat, query_lon, ref_lats, ref_lons)
    return float(np.min(dists))


def compute_path_errors_to_gps_reference(all_runs):
    point_rows = []
    summary_rows = []

    for order in ORDERS:
        gps_df = get_gps_ground_truth_points(all_runs[(order, "gps")])

        if len(gps_df) == 0:
            print(f"[Warning] GPS raw ground-truth points empty in {order}, skipping.")
            continue

        gps_lats = gps_df["raw_lat"].to_numpy()
        gps_lons = gps_df["raw_lon"].to_numpy()

        for profile in EVAL_PROFILES:
            cur_df = get_released_points(all_runs[(order, profile)])

            if len(cur_df) == 0:
                print(f"[Warning] No released points for {profile} in {order}.")
                continue

            errs = []
            for _, row in cur_df.iterrows():
                e = nearest_path_error_to_reference(
                    row["released_lat"], row["released_lon"],
                    gps_lats, gps_lons
                )
                errs.append(e)

            cur_df = cur_df.copy()
            cur_df["path_error_to_gps_ref_m"] = errs

            for _, row in cur_df.iterrows():
                point_rows.append({
                    "order": order,
                    "profile": profile,
                    "elapsed_ms": row.get("elapsed_ms", np.nan),
                    "timestamp": row.get("timestamp", None),
                    "timestamp_parsed": row.get("timestamp_parsed", pd.NaT),
                    "released_lat": row["released_lat"],
                    "released_lon": row["released_lon"],
                    "path_error_to_gps_ref_m": row["path_error_to_gps_ref_m"],
                    "release_offset_m": row.get("release_offset_m", np.nan),
                    "raw_accuracy_m": row.get("raw_accuracy_m", np.nan),
                    "epsilon_used": row.get("epsilon_used", np.nan),
                })

            arr = np.array(errs, dtype=float)
            summary_rows.append({
                "order": order,
                "profile": profile,
                "n_released": len(arr),
                "mean_path_error_m": float(np.nanmean(arr)) if len(arr) > 0 else np.nan,
                "median_path_error_m": float(np.nanmedian(arr)) if len(arr) > 0 else np.nan,
                "p90_path_error_m": float(np.nanpercentile(arr, 90)) if len(arr) > 0 else np.nan,
                "p95_path_error_m": float(np.nanpercentile(arr, 95)) if len(arr) > 0 else np.nan,
            })

    point_df = pd.DataFrame(point_rows)
    summary_df = pd.DataFrame(summary_rows)
    return point_df, summary_df


def ecdf(x):
    x = np.array(x, dtype=float)
    x = x[np.isfinite(x)]
    x = np.sort(x)
    if len(x) == 0:
        return np.array([]), np.array([])
    y = np.arange(1, len(x) + 1) / len(x)
    return x, y


