def save_fig(fig, filename_base, tight_version=False):
    png = OUT_DIR / f"{filename_base}.png"
    pdf = OUT_DIR / f"{filename_base}.pdf"

    fig.savefig(png, **SAVEFIG_KW)
    fig.savefig(pdf, **SAVEFIG_KW)

    print(f"[Saved] {png}")
    print(f"[Saved] {pdf}")

    if tight_version and EXPORT_TIGHT_VERSION:
        png_tight = OUT_DIR / f"{filename_base}_tight.png"
        pdf_tight = OUT_DIR / f"{filename_base}_tight.pdf"
        fig.savefig(png_tight, **SAVEFIG_KW)
        fig.savefig(pdf_tight, **SAVEFIG_KW)
        print(f"[Saved] {png_tight}")
        print(f"[Saved] {pdf_tight}")


def add_value_labels(ax, xs, ys, fmt="{:.2f}", dy=0.02):
    valid = [v for v in ys if pd.notna(v)]
    if len(valid) == 0:
        return

    ymin, ymax = ax.get_ylim()
    offset = (ymax - ymin) * dy if ymax > ymin else 0.1

    for xi, yi in zip(xs, ys):
        if pd.notna(yi):
            ax.text(
                xi, yi + offset, fmt.format(yi),
                ha="center", va="bottom",
                fontsize=9, fontweight="bold"
            )


