def remove_duplicate_consecutive_points(df, lat_col, lon_col):
    if len(df) <= 1:
        return df.copy()

    d = df.copy().reset_index(drop=True)
    keep = [True]
    for i in range(1, len(d)):
        same_lat = pd.notna(d.loc[i, lat_col]) and pd.notna(d.loc[i - 1, lat_col]) and d.loc[i, lat_col] == d.loc[i - 1, lat_col]
        same_lon = pd.notna(d.loc[i, lon_col]) and pd.notna(d.loc[i - 1, lon_col]) and d.loc[i, lon_col] == d.loc[i - 1, lon_col]
        keep.append(not (same_lat and same_lon))
    return d.loc[keep].reset_index(drop=True)


def choose_anchor_index(df, lat_col, lon_col):
    if len(df) == 0:
        return None
    d = df[[lat_col, lon_col]].dropna().reset_index(drop=True)
    if len(d) == 0:
        return None

    score = d[lat_col].rank(method="average", ascending=True) + d[lon_col].rank(method="average", ascending=True)
    return int(score.idxmin())


def nearest_neighbor_path_order(df, lat_col, lon_col):
    d = df.dropna(subset=[lat_col, lon_col]).copy().reset_index(drop=True)
    if len(d) <= 2:
        return d

    coords = d[[lat_col, lon_col]].to_numpy(dtype=float)
    n = len(coords)

    start_idx = choose_anchor_index(d, lat_col, lon_col)
    if start_idx is None:
        return d

    visited = np.zeros(n, dtype=bool)
    order = [start_idx]
    visited[start_idx] = True
    current = start_idx

    for _ in range(n - 1):
        remaining_idx = np.where(~visited)[0]
        if len(remaining_idx) == 0:
            break

        cur_lat, cur_lon = coords[current, 0], coords[current, 1]
        rem_lats = coords[remaining_idx, 0]
        rem_lons = coords[remaining_idx, 1]

        dists = pairwise_haversine_to_one(cur_lat, cur_lon, rem_lats, rem_lons)
        next_idx = remaining_idx[int(np.argmin(dists))]

        order.append(next_idx)
        visited[next_idx] = True
        current = next_idx

    return d.iloc[order].reset_index(drop=True)


def reconstruct_spatial_trajectory(df, lat_col, lon_col):
    d = df.dropna(subset=[lat_col, lon_col]).copy()
    if len(d) <= 2:
        return d.reset_index(drop=True)

    d = remove_duplicate_consecutive_points(d, lat_col, lon_col)
    d = nearest_neighbor_path_order(d, lat_col, lon_col)
    return d.reset_index(drop=True)


def sample_marker_indices(n, k=8):
    if n <= 0:
        return np.array([], dtype=int)
    if n <= k:
        return np.arange(n, dtype=int)
    return np.unique(np.linspace(0, n - 1, k).astype(int))


