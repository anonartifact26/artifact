# 12. Figure 6: Release offset vs path error scatter
# =========================================================

fig, ax = plt.subplots(figsize=FIGSIZE_WIDE, constrained_layout=False)
fig.subplots_adjust(**SUBPLOT_ADJUST_WIDE)

has_points = False

for profile in EVAL_PROFILES:
    d = point_errors_df[
        (point_errors_df["profile"] == profile)
        & point_errors_df["release_offset_m"].notna()
        & point_errors_df["path_error_to_gps_ref_m"].notna()
    ].copy()

    if len(d) == 0:
        continue

    has_points = True
    xdat = d["release_offset_m"].to_numpy(dtype=float)
    ydat = d["path_error_to_gps_ref_m"].to_numpy(dtype=float)

    ax.scatter(
        xdat,
        ydat,
        s=34,
        alpha=0.40,
        color=COLORS[profile],
        edgecolor="white",
        linewidth=0.4,
        label=profile.capitalize(),
        zorder=3
    )

    slope, intercept, r2 = simple_linear_fit(xdat, ydat)
    if slope is not None:
        xs = np.linspace(np.nanmin(xdat), np.nanmax(xdat), 200)
        ys = slope * xs + intercept
        resid = ydat - (slope * xdat + intercept)
        band = np.nanstd(resid) if len(resid) > 1 else 0.0

        ax.fill_between(
            xs, ys - band, ys + band,
            color=COLORS[profile], alpha=0.12, zorder=1
        )
        ax.plot(xs, ys, color=COLORS[profile], linewidth=2.6, alpha=0.98, zorder=4)

        label_x = xs[-1]
        label_y = ys[-1]
        r2_str = "nan" if pd.isna(r2) else f"{r2:.2f}"
        ax.text(
            label_x,
            label_y,
            f"  {profile.capitalize()} (R²={r2_str})",
            color=COLORS[profile],
            fontsize=9,
            va="center",
            fontweight="bold"
        )

