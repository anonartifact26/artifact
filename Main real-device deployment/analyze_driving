def infer_duration_hours(df):
    if len(df) < 2:
        return np.nan, "none"

    if "timestamp_parsed" in df.columns:
        t = df["timestamp_parsed"].dropna()
        if len(t) >= 2:
            dur_s = (t.iloc[-1] - t.iloc[0]).total_seconds()
            if dur_s > 0:
                return dur_s / 3600.0, "timestamp_parsed"

    if "elapsed_ms" in df.columns:
        vals = pd.to_numeric(df["elapsed_ms"], errors="coerce").dropna()
        if len(vals) >= 2:
            dur_ms = vals.iloc[-1] - vals.iloc[0]
            if dur_ms > 0:
                return dur_ms / 1000.0 / 3600.0, "elapsed_ms"

    return np.nan, "none"


def ecdf(x):
    x = np.array(x, dtype=float)
    x = x[np.isfinite(x)]
    x = np.sort(x)
    if len(x) == 0:
        return np.array([]), np.array([])
    y = np.arange(1, len(x) + 1) / len(x)
    return x, y


def all_xy_bounds(dfs_xy_pairs):
    xs = []
    ys = []
    for df, xcol, ycol in dfs_xy_pairs:
        if df is None or len(df) == 0:
            continue
        tmp = df[[xcol, ycol]].dropna()
        if len(tmp) == 0:
            continue
        xs.append(tmp[xcol].to_numpy())
        ys.append(tmp[ycol].to_numpy())

    if not xs or not ys:
        return None

    x_all = np.concatenate(xs)
    y_all = np.concatenate(ys)

    xmin, xmax = np.min(x_all), np.max(x_all)
    ymin, ymax = np.min(y_all), np.max(y_all)

    xpad = max((xmax - xmin) * 0.08, 0.0002)
    ypad = max((ymax - ymin) * 0.08, 0.0002)

    return xmin - xpad, xmax + xpad, ymin - ypad, ymax + ypad


